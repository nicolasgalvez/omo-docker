{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "vllm-mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM MLX (local)",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "mlx-community/Qwen3-8B-8bit": {
          "name": "Qwen3 8B 8bit"
        }
      }
    },
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:31b": {
          "name": "Gemma 4 31B"
        }
      }
    },
    "ollama-remote": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (remote server)",
      "options": {
        "baseURL": "http://192.168.1.100:11434/v1"
      },
      "models": {
        "gemma4:e4b": {
          "name": "Gemma 4 E4B"
        }
      }
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
